{
  "expo": {
    "name": "Mecenate",
    "slug": "mecenate-test",
    "scheme": "mecenate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F8FD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ru.mecenate.test"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F8FD"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "ru.mecenate.test"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "https://k8s.mectest.ru/test-app",
      "wsUrl": "wss://k8s.mectest.ru/test-app/ws"
    }
  }
}
